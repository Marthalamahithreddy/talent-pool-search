# =============================================================
# FILE: backend/.env.example
# PURPOSE: Template for all required environment variables.
#          Copy this to .env and fill in real values.
#          NEVER commit .env to git.
# =============================================================

# ---- Supabase (database) ------------------------------------
# Get these from: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- AWS S3 (file storage) ----------------------------------
# Create an IAM user with S3 full access, generate access keys
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=talent-pool-resumes

# ---- Gemini AI (resume parsing) ----------------------------
# Get from: Google AI Studio → aistudio.google.com → Get API Key
GEMINI_API_KEY=your-gemini-api-key-here

# ---- App settings ------------------------------------------
# Allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
