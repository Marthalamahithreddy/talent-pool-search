# =============================================================
# FILE: backend/.env.example
# PURPOSE: Template for all required environment variables.
#          Copy this to .env and fill in real values.
#          NEVER commit .env to git.
# =============================================================

# ---- Supabase (database) ------------------------------------
# Get these from: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- AWS S3 (file storage) ----------------------------------
# Create an IAM user with S3 full access, generate access keys
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=talent-pool-resumes

# ---- AI parsing provider -----------------------------------
# Choose the LLM backend: "groq" (default, recommended) or "gemini".
AI_PROVIDER=groq
AI_MAX_RETRIES=5

# ---- Groq (default) ----------------------------------------
# Get a free key at: console.groq.com → API Keys
# Free tier: ~30 req/min. llama-3.3-70b = 1000/day, llama-3.1-8b-instant = 14400/day
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_RPM=28

# ---- Gemini (fallback — used only if AI_PROVIDER=gemini) ----
# Get from: Google AI Studio → aistudio.google.com → Get API Key
#   gemini-2.0-flash → 15 req/min, 1500/day | gemini-2.0-flash-lite → 30 req/min (set GEMINI_RPM=28)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_RPM=14

# ---- App settings ------------------------------------------
# Allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
