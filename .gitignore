# =============================================================
# FILE: .gitignore (repo root)
# PURPOSE: Catch-all ignores. Backend and frontend also have their
#          own .gitignore files for tool-specific artifacts.
# =============================================================

# Secrets — never commit real env files
.env
.env.local
**/.env
**/.env.local

# Python
**/venv/
**/.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/

# Node / Next.js
**/node_modules/
**/.next/
**/*.tsbuildinfo
**/next-env.d.ts

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
